# Copy this file to .env and fill in your keys. Never commit .env.

# Required for Pinecone (vector DB) - used by langchainbot, chatbot, similarity_search, descriptions_to_pinecone, live_demo
PINECONE_API_KEY=your_pinecone_api_key_here

# Required for OpenAI (LLM) - used by langchainbot, chatbot, RAGDemo.ipynb
OPENAI_API_KEY=your_openai_api_key_here

# Optional: for LangSmith tracing (e.g. RAGDemo.ipynb)
# LANGCHAIN_API_KEY=your_langchain_api_key_here

# Optional: for live_demo.ipynb when using Hugging Face Inference API
# HUGGINGFACE_HUB_TOKEN=your_huggingface_token_here
